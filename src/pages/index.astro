---
import Layout from '../layouts/Layout.astro';
import talksData from '../data/talks.json';

const { eras, taxonomy_pillars } = talksData;
---

<Layout title="RainbowBreeze | Public Speaking Hub">
	<main class="max-w-4xl mx-auto px-6 py-20">
		<!-- Hero Section -->
		<header class="mb-24">
			<h1 class="text-6xl md:text-8xl font-black tracking-tighter mb-4 italic">
				RAINBOW<span class="text-yellow-400">BREEZE</span>
			</h1>
			<p class="text-xl md:text-2xl text-slate-400 font-medium max-w-2xl leading-relaxed">
				Strategic leadership, community operations, and the intersection of humanity and technology. 
				Two decades of insights, shared on stages worldwide.
			</p>
		</header>

		<!-- Eras Timeline -->
		<section class="mb-24">
			<h2 class="text-sm uppercase tracking-widest text-yellow-400 font-bold mb-12 flex items-center gap-4">
				<span class="h-px w-8 bg-yellow-400"></span> THE ERAS
			</h2>
			
			<div class="space-y-16">
				{eras.map((era) => (
					<div class="group relative pl-8 border-l border-slate-800 hover:border-yellow-400 transition-colors">
						<div class="absolute -left-1.5 top-0 w-3 h-3 bg-slate-800 rounded-full group-hover:bg-yellow-400 transition-colors"></div>
						<span class="text-sm font-mono text-slate-500 mb-2 block">{era.years}</span>
						<h3 class="text-2xl md:text-3xl font-bold mb-3 group-hover:text-yellow-400 transition-colors">
							{era.name}
						</h3>
						<p class="text-slate-400 mb-4 text-lg">
							Focus: <span class="text-slate-200">{era.focus}</span>
						</p>
						<div class="flex flex-wrap gap-2">
							{era.notable_talks.map((talk) => (
								<span class="text-xs px-2 py-1 bg-slate-900 border border-slate-800 rounded text-slate-400 italic">
									{talk}
								</span>
							))}
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- Taxonomy / Pillars -->
		<section>
			<h2 class="text-sm uppercase tracking-widest text-yellow-400 font-bold mb-8 flex items-center gap-4">
				<span class="h-px w-8 bg-yellow-400"></span> CORE TOPICS
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
				{taxonomy_pillars.map((pillar) => (
					<div class="p-6 bg-slate-900/50 border border-slate-800 rounded-xl hover:bg-slate-900 transition-all cursor-default group">
						<p class="text-lg font-bold group-hover:text-yellow-400 transition-colors">{pillar}</p>
					</div>
				))}
			</div>
		</section>

		<footer class="mt-32 pt-12 border-t border-slate-900 text-slate-600 text-sm font-mono">
			&copy; {new Date().getFullYear()} ALFREDO MORRESI. PROCESSED BY SAMANTHA AI.
		</footer>
	</main>
</Layout>
