---
import '../styles/global.css'

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-slate-950 text-slate-100 selection:bg-yellow-400 selection:text-slate-950">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="RainbowBreeze Portfolio Site" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen font-sans antialiased">
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--accent: #FFD700;
	}
</style>
